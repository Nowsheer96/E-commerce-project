<section class="bg-light py-5">
  <div class="container">
    <div class="row g-4">
      <div class="col-lg-8">
        <div class="card border-0 shadow-sm mb-4">
          <div class="card-header bg-white py-3">
            <h5 class="mb-0 fw-bold">My Cart ({{products.length}})</h5>
          </div>
          <div class="card-body p-0">
            {{#each products}}
            <div class="row align-items-center g-0 p-3 border-bottom cart-item-row">
              <div class="col-3 col-md-2">
                <div class="img-container bg-white p-1 rounded border">
                  <img src="/product-images/{{this.product._id}}.jpg" 
                       alt="{{this.product.Name}}" 
                       class="img-fluid rounded"
                       style="height: 80px; width: 100%; object-fit: contain;">
                </div>
              </div>

              <div class="col-9 col-md-10 ps-3">
                <div class="d-flex justify-content-between">
                  <div>
                    <h6 class="fw-bold mb-1">{{this.product.Name}}</h6>
                    <p class="text-muted small mb-2">Category: {{this.product.Category}}</p>
                    <div class="h6 fw-bold text-dark">₹{{this.product.Price}}</div>
                  </div>
                  
                  <div class="qty-control d-flex align-items-center bg-light rounded px-2" style="height: 40px;">
                    <button class="btn btn-sm p-1 border-0" 
                            onclick="changeQuantity('{{this._id}}','{{this.product._id}}', -1)">
                      <i class="fas fa-minus small"></i>
                    </button>
                    <span id="{{this.product._id}}" class="px-3 fw-bold">{{this.quantity}}</span>
                    <button class="btn btn-sm p-1 border-0" 
                            onclick="changeQuantity('{{this._id}}','{{this.product._id}}', 1)">
                      <i class="fas fa-plus small"></i>
                    </button>
                  </div>
                </div>

                <div class="mt-2">
                  <button class="btn btn-link text-danger text-decoration-none p-0 small fw-bold" 
                          onclick="removeProduct('{{this._id}}','{{this.product._id}}')">
                    REMOVE
                  </button>
                </div>
              </div>
            </div>
            {{/each}}
          </div>
        </div>
      </div>

      <div class="col-lg-4">
        <div class="card border-0 shadow-sm sticky-top" style="top: 20px;">
          <div class="card-header bg-white py-3">
            <h6 class="text-muted fw-bold mb-0">PRICE DETAILS</h6>
          </div>
          <div class="card-body">
            <div class="d-flex justify-content-between mb-3">
              <span>Price ({{products.length}} items)</span>
              <span>₹<span id="sub-total">{{total}}</span></span>
            </div>
            <div class="d-flex justify-content-between mb-3">
              <span>Delivery Charges</span>
              <span class="text-success">FREE</span>
            </div>
            <hr class="dashed">
            <div class="d-flex justify-content-between mb-3">
              <h5 class="fw-bold">Total Amount</h5>
              <h5 class="fw-bold text-primary">₹<span id="total">{{total}}</span></h5>
            </div>
            <div class="text-success small fw-bold mb-4">
               <i class="fas fa-shield-alt"></i> Safe and Secure Payments. 100% Authentic products.
            </div>
            <a href="/place-order" class="btn btn-warning w-100 fw-bold py-3 shadow-sm place-order-btn">
              PLACE ORDER
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .cart-item-row:hover {
    background-color: #fafafa;
  }
  
  .dashed {
    border: none;
    border-top: 1px dashed #ddd;
    color: #fff;
    background-color: #fff;
    height: 1px;
    width: 100%;
  }

  .place-order-btn {
    background-color: #fb641b !important; /* Flipkart Orange */
    border-color: #fb641b !important;
    color: white !important;
    font-size: 1rem;
    letter-spacing: 0.5px;
  }

  .place-order-btn:hover {
    background-color: #f4510b !important;
  }

  .qty-control button:hover {
    color: #fb641b;
  }
</style>

<script>

  function changeQuantity(cartId,prdId,count)
  { let quantity =
  parseInt(document.getElementById(prdId).innerHTML);
   count = parseInt(count);
  $.ajax({
     url:'/change-product-qty',
      data:{ cart:cartId,
       product:prdId,
  count:count,
   quantity: quantity },
    method:'post',
     success:(response)=>{ if
  (response.removeProduct) { alert("Product Removed from cart");
  location.reload();
   } else {
     // Update the quantity in the span
  document.getElementById(prdId).innerHTML = quantity + count; 
  document.getElementById('total').innerHTML = response.total;
  // You'll need to add a class or ID to the minus button to target it easily
   } } }) }

 function removeProduct(cartId, prdId) {
    $.ajax({
      url: '/remove-Product',
      data: {
        cart: cartId,
        product: prdId
      }, // Added the missing comma here
      method: 'post',
      success: (response) => {
        if (response.removeProduct) {
          alert("Product Removed from Cart Successfully");
          location.reload();
        }
      }
    });
  }
  

</script>