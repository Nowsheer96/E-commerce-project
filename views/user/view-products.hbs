<section class="bg-light py-5">
  <div class="container">
    <div class="row g-4">
      {{#each products}}
      <div class="col-12 col-sm-6 col-md-4 col-lg-3">
        <div class="card h-100 product-card border-0 shadow-sm">
          <div class="image-wrapper p-3">
            <img class="card-img-top img-fluid" 
                 src="/product-images/{{this._id}}.jpg" 
                 alt="{{this.Name}}">
          </div>

          <div class="card-body d-flex flex-column pt-0">
            <h6 class="card-title text-dark fw-bold mb-1 text-truncate-2">
              {{this.Name}}
            </h6>
            
            <div class="text-warning small mb-2">
                <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star-half-alt"></i>
                <span class="text-muted ms-1">(4.5)</span>
            </div>

            <div class="mb-2">
                <span class="h5 fw-bold mb-0">{{this.Price}}</span> 
                <span class="text-muted text-decoration-line-through small ms-2 mrp-price" data-price="{{this.Price}}"></span>
                <span class="text-success small ms-2 fw-bold">33% off</span>
            </div>

            <div id="desc-container-{{this._id}}" class="mb-3">
              <p class="card-text text-muted small mb-1 description-text truncated">
                {{this.Description}}
              </p>
              <a href="javascript:void(0)" class="read-more-link small text-primary text-decoration-none" onclick="toggleText('{{this._id}}')">Read more</a>
            </div>

            <button onclick="addToCart('{{this._id}}')" class="btn btn-warning w-100 mt-auto fw-bold py-2 add-btn">
              Add to Cart
            </button>
          </div>
        </div>
      </div>
      {{/each}}
    </div>
  </div>
</section>

<style>
  /* Amazon/Flipkart inspired card styling */
  .product-card {
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    border-radius: 8px;
    overflow: hidden;
  }

  .product-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.12) !important;
  }

  .image-wrapper {
    height: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #fff;
  }

  .image-wrapper img {
    max-height: 100%;
    object-fit: contain;
  }

  .text-truncate-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;  
    overflow: hidden;
    height: 2.5rem;
  }

  /* Amazon Gold Button Style */
  .add-btn {
    background-color: #ffd814;
    border-color: #fcd200;
    color: #0f1111;
    border-radius: 20px;
  }

  .add-btn:hover {
    background-color: #f7ca00;
    border-color: #f2c200;
  }

  .truncated {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<script>
  function addToCart(prdId) {
    $.ajax({
        url: '/add-to-cart/' + prdId,
        method: 'get',
        success: (response) => {
            if (response.status) {
                // Update badge count
                let count = $('#cart-count').html();
                count = parseInt(count) || 0;
                $("#cart-count").html(count + 1);
            } else if (response.loginRedirect) {
                // Manually redirect to login if session expired
                window.location.href = '/login';
            }
        }
    });
}


$(document).ready(function() {
    $('.mrp-price').each(function() {
        let currentPrice = parseFloat($(this).data('price'));
        if (!isNaN(currentPrice)) {
            // Calculate what the price was before a 33% discount
            let originalPrice = Math.round(currentPrice / 0.67); 
            $(this).html('₹' + originalPrice.toLocaleString('en-IN'));
        }
    });
});
</script>