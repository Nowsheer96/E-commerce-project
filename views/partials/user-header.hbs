<header class="header-main">
  <nav class="navbar navbar-expand-lg navbar-dark bg-amazon-dark py-2">
    <div class="container-fluid px-2 px-lg-4">
      
      <button class="navbar-toggler border-0 p-1 me-2" type="button" data-bs-toggle="collapse" data-bs-target="#navContent">
        <span class="navbar-toggler-icon" style="width: 1.2em; height: 1.2em;"></span>
      </button>

      <a class="navbar-brand fw-bold text-white fs-5 m-0" href="/">
        Nofa<span class="text-warning">Cart</span>
      </a>

      <div class="d-flex align-items-center order-lg-3 ms-auto">
        
        <div class="dropdown d-none d-lg-block me-3">
          <a class="nav-link dropdown-toggle text-white fw-bold d-flex flex-column lh-1" href="#" id="desktopAccount" data-bs-toggle="dropdown">
            <span style="font-size: 0.7rem; color: #ccc; font-weight: normal;">Hello, {{#if user}}{{user.Name}}{{else}}Sign in{{/if}}</span>
            <span>Account</span>
          </a>
          <ul class="dropdown-menu dropdown-menu-end shadow mt-2">
            {{#if user}}
              <li><a class="dropdown-item" href="/orderList"><i class="fas fa-box me-2"></i>Orders</a></li>
              <li><hr class="dropdown-divider"></li>
              <li><a class="dropdown-item text-danger" href="/logout"><i class="fas fa-sign-out-alt me-2"></i>Logout</a></li>
            {{else}}
              <li><a class="dropdown-item" href="/login">Login</a></li>
            {{/if}}
          </ul>
        </div>

        {{#if user}}
        <a class="nav-link text-white position-relative p-2 cart-link" href="/viewCart/{{user._id}}">
           <i class="fas fa-shopping-cart fs-4"></i>
           <span id="cart-count" class="badge rounded-pill bg-warning text-dark position-absolute top-0 start-100 translate-middle border border-dark border-1" style="font-size: 0.65rem;">
             {{cartCount}}
           </span>
        </a>
        {{/if}}
      </div>

      <div class="collapse navbar-collapse order-lg-2" id="navContent">
        <ul class="navbar-nav me-auto mb-2 mb-lg-0 mt-3 mt-lg-0">
          <li class="nav-item">
            <a class="nav-link text-white px-lg-3" href="/"><i class="fas fa-home me-2 d-lg-none"></i>Product</a>
          </li>
          {{#if user}}
            <li class="nav-item d-lg-none"> <a class="nav-link text-white" href="/orderList"><i class="fas fa-box me-2"></i>Orders</a>
            </li>
          {{/if}}
          
          <li class="nav-item d-lg-none border-top mt-2 pt-2">
            <a class="nav-link text-white fw-bold" href="#">
              <i class="fas fa-user-circle me-2"></i>{{#if user}}{{user.Name}}{{else}}Account{{/if}}
            </a>
            {{#if user}}
              <a class="nav-link text-danger small ms-4" href="/logout">Logout</a>
            {{else}}
              <a class="nav-link text-white small ms-4" href="/login">Login</a>
            {{/if}}
          </li>
        </ul>
      </div>

    </div>
  </nav>
</header>

<style>
  .bg-amazon-dark { background-color: #131921 !important; }
  
  .nav-link:hover { color: #febd69 !important; }
  
  .cart-link { transition: transform 0.2s ease; }
  .cart-link:hover { transform: scale(1.1); }

  /* Desktop specific spacing */
  @media (min-width: 992px) {
    .navbar-collapse {
      margin-left: 2rem;
    }
  }

  /* Mobile specific adjustments */
  @media (max-width: 991.98px) {
    .navbar-brand { font-size: 1.2rem; }
  }
</style>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>