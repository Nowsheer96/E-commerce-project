
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<section class="bg-light min-vh-100 py-5">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold mb-1">Customer Order Management</h2>
                <p class="text-muted small mb-0">Manage, track, and update customer shipments</p>
            </div>
            <button class="btn btn-white shadow-sm border rounded-3 px-3">
                <i class="fas fa-download me-2 text-muted"></i> Export Report
            </button>
        </div>

        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="bg-white border-bottom">
                        <tr>
                            <th class="ps-4 py-3 text-uppercase small fw-bold text-muted">Order Date</th>
                            <th class="py-3 text-uppercase small fw-bold text-muted">Customer</th>
                            <th class="py-3 text-uppercase small fw-bold text-muted">Shipping Details</th>
                            <th class="py-3 text-uppercase small fw-bold text-muted">Amount</th>
                            <th class="py-3 text-uppercase small fw-bold text-muted">Method</th>
                            <th class="py-3 text-uppercase small fw-bold text-muted text-center">Status</th>
                            <th class="pe-4 py-3 text-uppercase small fw-bold text-muted text-end">Manage</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each orders}}
                        <tr class="order-row">
                            <td class="ps-4">
                                <span class="fw-medium text-dark">{{formatDate this.date}}</span>
                            </td>
                            <td>
                                <div class="d-flex align-items-center">
                                  
                                    <span class="fw-semibold">{{this.customerName}}</span>
                                </div>
                            </td>
                            <td>
                                <div class="small">
                                    <div class="text-dark">{{this.deliveryDetails.address}}</div>
                                    <div class="text-muted"><i class="fas fa-phone-alt me-1 x-small"></i>{{this.deliveryDetails.mobile}}</div>
                                </div>
                            </td>
                            <td>
                                <span class="fw-bold text-dark">₹{{this.totalAmount}}</span>
                            </td>
                            <td>
                                <span class="badge bg-light text-dark border fw-normal">{{this.paymentMethod}}</span>
                            </td>
                            <td class="text-center">
                                <span class="status-badge {{this.status}}" id="status-{{this._id}}">
                                    {{this.status}}
                                </span>
                            </td>
                        <td class="pe-4 text-end">
                            <div class="dropdown">
                                <button class="btn btn-icon-soft" type="button" data-bs-toggle="dropdown" aria-expanded="false" data-bs-boundary="viewport">
                                    <i class="fas fa-ellipsis-v"></i>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0 p-2">
                                    <li class="small text-muted px-3 py-1 text-uppercase fw-bold" style="font-size: 0.65rem;">Set Status</li>
                                    <li><a class="dropdown-item rounded-2" href="javascript:void(0)" onclick="updateStatus('{{this._id}}', 'Shipped')"><i class="fas fa-shipping-fast me-2 text-primary"></i> Mark as Shipped</a></li>
                                    <li><a class="dropdown-item rounded-2" href="javascript:void(0)" onclick="updateStatus('{{this._id}}', 'Delivered')"><i class="fas fa-check-circle me-2 text-success"></i> Mark as Delivered</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item rounded-2 text-danger" href="javascript:void(0)" onclick="updateStatus('{{this._id}}', 'Cancelled')"><i class="fas fa-times-circle me-2"></i> Cancel Order</a></li>
                                </ul>
                            </div>
                        </td>
                        </tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<style>
    /* Modern Dashboard Styling */
    .bg-light { background-color: #f8f9fa !important; }
    .bg-primary-light { background-color: #e7f0ff; }
    .avatar-sm { width: 32px; height: 32px; font-size: 0.8rem; }
    
    .table thead th {
        font-size: 0.75rem;
        letter-spacing: 0.05em;
    }

    .order-row:hover { background-color: #fcfcfc; }

    /* Modern Status Badges */
    .status-badge {
        padding: 0.4em 1em;
        border-radius: 50px;
        font-size: 0.75rem;
        font-weight: 700;
        display: inline-block;
        text-transform: uppercase;
        letter-spacing: 0.02em;
    }

    /* Status Colors */
    .status-badge.Placed { background-color: #fff4e5; color: #b76e00; }
    .status-badge.Shipped { background-color: #e7f0ff; color: #0052cc; }
    .status-badge.Delivered { background-color: #e6fcf5; color: #087f5b; }
    .status-badge.Cancelled { background-color: #fff5f5; color: #e03131; }

    /* Utility */
    .btn-icon-soft {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        border: none;
        background: transparent;
        color: #adb5bd;
        transition: all 0.2s;
    }
    .btn-icon-soft:hover { background: #eee; color: #212529; }
    .x-small { font-size: 0.7rem; }
</style>

<script>
function updateStatus(orderId, status) {
    $.ajax({
        url: '/admin/update-order-status',
        method: 'post',
        data: {
            orderId: orderId,
            status: status
        },
        success: (response) => {
            if (response.status) {
                // Update the badge text and color dynamically
                let badge = document.getElementById('status-' + orderId);
                badge.className = "status-badge " + status;
                badge.innerHTML = status;
                if(status === 'Shipped') {
                    badge.className = "badge rounded-pill bg-success";
                }
                alert("Order status updated to " + status);
            }
        }
    })
}
</script>