
<section>
  <div class="container mt-4">
    <div class="row mb-4">
      <div class="col-12 d-flex justify-content-between align-items-center">
        <h2 class="fw-bold">Product Management</h2>
        <a href="/admin/add-product" class="btn btn-success px-4">
          <i class="fas fa-plus"></i> Add Product
        </a>
      </div>
    </div>

    <div class="card shadow-sm">
      <div class="card-body p-0">
        <table id="productsTable" class="table table-hover mb-0 align-middle">
          <thead class="table-dark">
            <tr>
              <th scope="col" class="ps-4">No</th>
              <th scope="col">Title</th>
              <th scope="col">Category</th>
              <th scope="col" style="width: 30%;">Description</th>
              <th scope="col">Price</th>
              <th scope="col">Image</th>
              <th scope="col" class="text-center pe-4">Actions</th>
            </tr>
          </thead>
          <tbody>
            {{#each products}}
            <tr>
              <th scope="row" class="ps-4">{{increment @index}}</th>
              <td class="fw-bold">{{this.Name}}</td>
              <td><span class="badge bg-light text-dark border">{{this.Category}}</span></td>
              <td>
                <p class="mb-0 text-muted" style="font-size: 0.85rem; line-height: 1.4;">
                  {{this.Description}}
                </p>
              </td>
              <td class="fw-bold text-success">₹{{this.Price}}</td>
              <td>
                <img src="/product-images/{{this._id}}.jpg" 
                     class="img-thumbnail" 
                     style="width: 50px; height: 50px; object-fit: cover;" 
                     alt="product">
              </td>
              <td class="text-center pe-4">
                <div class="btn-group" role="group">
                  <a href="/admin/edit-product/{{this._id}}" class="btn btn-primary btn-sm mx-1 rounded">
                    Edit
                  </a>
                  <a href="/admin/delete-product/{{this._id}}" 
                     class="btn btn-danger btn-sm mx-1 rounded" 
                     onclick="return confirm('Are you sure you want to delete {{this.Name}}?')">
                    Delete
                  </a>
                </div>
              </td>
            </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>

<script>
$( function () {
    $('#productsTable').DataTable();
} );

</script>