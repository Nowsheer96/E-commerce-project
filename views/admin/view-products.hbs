
<section class="bg-light min-vh-100 py-5">
  <div class="container">
    <div class="row align-items-center mb-5">
      <div class="col-md-6">
        <h2 class="fw-bold text-dark mb-1">Product Inventory</h2>
        <p class="text-muted mb-0">Manage your catalog, prices, and stock levels</p>
      </div>
      <div class="col-md-6 text-md-end mt-3 mt-md-0">
        <a href="/admin/add-product" class="btn btn-primary px-4 py-2 fw-bold shadow-sm rounded-3">
          <i class="fas fa-plus-circle me-2"></i>Add New Product
        </a>
      </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
      <div class="card-body p-0">
        <div class="table-responsive">
          <table id="productsTable" class="table table-hover align-middle mb-0">
            <thead class="bg-white border-bottom">
              <tr>
                <th class="ps-4 py-3 text-uppercase small fw-bold text-muted">ID</th>
                <th class="py-3 text-uppercase small fw-bold text-muted">Product Info</th>
                <th class="py-3 text-uppercase small fw-bold text-muted">Category</th>
                <th class="py-3 text-uppercase small fw-bold text-muted" style="width: 25%;">Description</th>
                <th class="py-3 text-uppercase small fw-bold text-muted">Price</th>
                <th class="text-center pe-4 py-3 text-uppercase small fw-bold text-muted">Actions</th>
              </tr>
            </thead>
            <tbody>
              {{#each products}}
              <tr class="product-row">
                <td class="ps-4 text-muted small">#{{increment @index}}</td>
                <td>
                  <div class="d-flex align-items-center">
                    <div class="img-wrapper me-3 border rounded-3 p-1 bg-white">
                      <img src="/product-images/{{this._id}}.jpg" 
                           alt="product"
                           style="width: 45px; height: 45px; object-fit: cover;"
                           class="rounded-2">
                    </div>
                    <span class="fw-bold text-dark">{{this.Name}}</span>
                  </div>
                </td>
                <td>
                  <span class="badge rounded-pill bg-info-soft text-info border-0 px-3">
                    {{this.Category}}
                  </span>
                </td>
                <td>
                  <p class="mb-0 text-muted small text-truncate-2">
                    {{this.Description}}
                  </p>
                </td>
                <td>
                  <span class="fw-bold text-dark">₹{{this.Price}}</span>
                </td>
                <td class="text-center pe-4">
                  <div class="d-flex justify-content-center gap-2">
                    <a href="/admin/edit-product/{{this._id}}" 
                       class="btn btn-icon-action btn-outline-primary" 
                       title="Edit Product">
                      <i class="fas fa-edit"></i>
                    </a>
                    <a href="/admin/delete-product/{{this._id}}" 
                       class="btn btn-icon-action btn-outline-danger" 
                       title="Delete Product"
                       onclick="return confirm('Delete {{this.Name}}?')">
                      <i class="fas fa-trash-alt"></i>
                    </a>
                  </div>
                </td>
              </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Modern Dashboard Theme */
  .bg-light { background-color: #f8f9fa !important; }
  
  /* Table Header Styling */
  .table thead th {
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    background-color: #ffffff;
  }

  /* Soft Badges */
  .bg-info-soft {
    background-color: #e7f6f8;
    color: #0dcaf0;
  }

  /* Action Buttons */
  .btn-icon-action {
    width: 34px;
    height: 34px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    transition: all 0.2s ease;
  }

  .btn-icon-action:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 8px rgba(0,0,0,0.1);
  }

  /* Description Truncation */
  .text-truncate-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;  
    overflow: hidden;
    line-height: 1.5;
  }

  .product-row:hover {
    background-color: #fafafa;
  }

  /* DataTables Customization */
  .dataTables_wrapper .dataTables_paginate .paginate_button.current {
    background: #0d6efd !important;
    color: white !important;
    border: none !important;
    border-radius: 6px;
  }
</style>

<script>
$( function () {
    $('#productsTable').DataTable({
      "pageLength": 50, // Sets the default to 50 entries
        "lengthMenu": [ [10, 25, 50, 100, -1], [10, 25, 50, 100, "All"] ] 
        // The -1 value tells DataTables to show all records
    });
} );

</script>